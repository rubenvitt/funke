# Kopiere nach .env und fülle aus. .env NIEMALS committen.

# Auth-Token für Obsidian Sync (einmalig holen):
#   docker compose run --rm --entrypoint get-token obsidian-sync
OBSIDIAN_AUTH_TOKEN=

# Exakter remote Vault-Name (case-sensitive), z. B.:
VAULT_NAME=r-notes

# Vault-E2E-Verschlüsselungspasswort (nur falls aktiviert; sonst leer lassen):
VAULT_PASSWORD=

# Relay-Token: langer Zufallswert (z. B. `openssl rand -hex 24`).
# MUSS identisch sein mit dem Relay-Token in der Funke-App.
FUNKE_TOKEN=
